---
import { Star, Quote } from 'lucide-react';

const testimonials = [
  {
    name: "María González",
    role: "Directora de Clínica Salud+",
    image: "/images/avatar-1.jpg",
    content: "El chatbot de IA revolucionó nuestra atención al cliente. Ahora respondemos consultas 24/7 y nuestros pacientes están más satisfechos que nunca.",
    rating: 5
  },
  {
    name: "Carlos Ramírez",
    role: "CEO de TechStore",
    image: "/images/avatar-2.jpg",
    content: "El sistema de recomendaciones ML aumentó nuestras ventas en un 45%. La experiencia de usuario es excepcional y el código es impecable.",
    rating: 5
  },
  {
    name: "Ana Martínez",
    role: "Gerente de Marketing",
    image: "/images/avatar-3.jpg",
    content: "Profesional, rápido y efectivo. El bot de WhatsApp automatizó completamente nuestro proceso de ventas. ¡Altamente recomendado!",
    rating: 5
  }
];
---

<section id="testimonials" class="section testimonials-section">
  <div class="container">
    <div class="section-header scroll-reveal">
      <h2 class="section-title">
        Lo Que Dicen Mis <span class="gradient-text">Clientes</span>
      </h2>
      <p class="section-description">
        Testimonios reales de clientes satisfechos
      </p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((testimonial, index) => (
        <article class="testimonial-card scroll-reveal" style={`animation-delay: ${index * 100}ms`}>
          <div class="quote-icon">
            <Quote size={32} />
          </div>

          <div class="rating">
            {Array.from({ length: testimonial.rating }).map((_, i) => (
              <Star key={i} size={16} fill="currentColor" />
            ))}
          </div>

          <p class="testimonial-content">{testimonial.content}</p>

          <div class="testimonial-author">
            <div class="author-avatar">
              <img src={testimonial.image} alt={testimonial.name} loading="lazy" />
            </div>
            <div class="author-info">
              <h4 class="author-name">{testimonial.name}</h4>
              <p class="author-role">{testimonial.role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    background: var(--bg-primary);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border);
    position: relative;
    transition: all var(--transition-base);
  }

  .testimonial-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-xl);
    border-color: var(--primary);
  }

  .quote-icon {
    color: var(--primary);
    opacity: 0.2;
    margin-bottom: 1rem;
  }

  .rating {
    display: flex;
    gap: 0.25rem;
    color: #f59e0b;
    margin-bottom: 1.5rem;
  }

  .testimonial-content {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--bg-tertiary);
  }

  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .author-role {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
  }

  @media (max-width: 640px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
